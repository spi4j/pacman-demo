  <viewContainers xmi:id="_orVAIq2iEfChX404RhFJ7A" technicalid="_orVAIK2iEfChX404RhFJ7A" createdOn="2025-10-20T12:50:47.459+0200" modifiedOn="2025-10-22T07:23:02.109+0200" name="availableRequestsPanel">
    <widget href="pathmap://cinematic/toolkits/pacman-react-spa-dsfr#_cVIkIJJGEfCaOp8KF-MYRg"/>
    <viewStyle xmi:id="_orVAI62iEfChX404RhFJ7A" technicalid="_orVAIa2iEfChX404RhFJ7A"/>
    <ownedElements xsi:type="cinematic-view:ViewElement" xmi:id="_oBCJ4q46EfChX404RhFJ7A" technicalid="_oBCJ4K46EfChX404RhFJ7A" description="Notre objectif est de vous offrir un acc&#xe8;s simplifi&#xe9;, s&#xe9;curis&#xe9; et centralis&#xe9; &#xe0; l&#x2019;ensemble de vos d&#xe9;marches, quelles qu&#x2019;elles soient. En quelques clics, vous pouvez initier, suivre et finaliser vos demandes, sans d&#xe9;placement inutile et avec l&#x2019;assurance d&#x2019;un accompagnement clair &#xe0; chaque &#xe9;tape." createdOn="2025-10-21T06:58:46.527+0200" modifiedOn="2025-10-21T07:05:35.419+0200" name="textHighLight" label="">
      <metadatas xmi:id="_oBDYAa46EfChX404RhFJ7A" technicalid="_oBDYAK46EfChX404RhFJ7A"/>
      <widget href="pathmap://cinematic/toolkits/pacman-react-spa-dsfr#_XElUUJH1EfCF6-2aQyGFWw"/>
      <viewStyle xmi:id="_oBCJ4646EfChX404RhFJ7A" technicalid="_oBCJ4a46EfChX404RhFJ7A"/>
    </ownedElements>
    <ownedElements xsi:type="cinematic-view:ViewElement" xmi:id="_PHwCgq5CEfCUy8saRL61hA" technicalid="_PHwCgK5CEfCUy8saRL61hA" description="      &lt;p>&#xD;&#xA;        Sur notre site, vous pouvez effectuer l&#x2019;ensemble de vos d&#xe9;marches administratives locales de mani&#xe8;re simple et s&#xe9;curis&#xe9;e.&#xD;&#xA;      &lt;/p>&#xD;&#xA;      &lt;p>Cela comprend :&lt;/p>&#xD;&#xA;      &lt;ul>&#xD;&#xA;        &lt;li>Les demandes li&#xe9;es &#xe0; l&#x2019;&#xe9;tat civil (actes de naissance, de mariage, de d&#xe9;c&#xe8;s)&lt;/li>&#xD;&#xA;        &lt;li>Les documents officiels comme les cartes d&#x2019;identit&#xe9;, les passeports ou les titres de s&#xe9;jour&lt;/li>&#xD;&#xA;        &lt;li>Les inscriptions scolaire et p&#xe9;riscolaire&lt;/li>&#xD;&#xA;        &lt;li>Les d&#xe9;marches relatives au logement et &#xe0; l&#x2019;urbanisme (certificats, autorisations de construire, d&#xe9;clarations pr&#xe9;alables)&lt;/li>&#xD;&#xA;        &lt;li>Acc&#xe9;der aux services sociaux et d&#x2019;accompagnement (aides financi&#xe8;res, emploi, services aux personnes &#xe2;g&#xe9;es ou en situation de handicap)&lt;/li>&#xD;&#xA;        &lt;li>R&#xe9;gler vos obligations fiscales locales et certaines factures ou redevances&lt;/li>&#xD;&#xA;      &lt;/ul>&#xD;&#xA;      &lt;p>&#xD;&#xA;        Le site permet aussi de signaler des incidents sur la voirie et de s&#x2019;informer sur la culture, le sport et la vie associative.&#xD;&#xA;      &lt;/p>&#xD;&#xA;      &lt;p>&#xD;&#xA;        Chaque d&#xe9;marche est accompagn&#xe9;e d&#x2019;instructions d&#xe9;taill&#xe9;es et d&#x2019;outils de suivi pour faciliter la compr&#xe9;hension et le traitement rapide de vos demandes.&#xD;&#xA;      &lt;/p>" createdOn="2025-10-21T07:53:15.433+0200" modifiedOn="2025-10-23T18:26:52.997+0200" name="availableRequestsContent" label="Liste des d&#xe9;marches disponibles sur le site">
      <metadatas xmi:id="_PHwpka5CEfCUy8saRL61hA" technicalid="_PHwpkK5CEfCUy8saRL61hA"/>
      <widget href="pathmap://cinematic/toolkits/pacman-react-spa-dsfr#_n3SHYJHzEfCF6-2aQyGFWw"/>
      <viewStyle xmi:id="_PHwCg65CEfCUy8saRL61hA" technicalid="_PHwCga5CEfCUy8saRL61hA"/>
    </ownedElements>
